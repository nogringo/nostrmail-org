---
interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
}

const { 
	title, 
	description = "The open, sovereign and decentralized email protocol powered by Nostr. Own your identity and inbox without central authorities or gatekeepers.",
	image = "/og-image.png",
	canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://nostrmail.org").toString()
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- JSON-LD -->
		<script type="application/ld+json" is:inline>
			{
			  "@context": "https://schema.org",
			  "@type": "SoftwareApplication",
			  "name": "Nostr Mail",
			  "operatingSystem": "All",
			  "applicationCategory": "CommunicationApplication",
			  "description": "Nostr Mail is a decentralized email protocol and client built on top of the Nostr network.",
			  "offers": {
				"@type": "Offer",
				"price": "0"
			  }
			}
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Fira+Code:wght@400;600&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		/* Dark mode (default) */
		--bg: #0A0A0A;
		--fg: #F5F5F5;
		--accent-protocol: #673AB7;
		--accent-app: #00BCD4;
		--accent-lib: #4CAF50;
		--muted: #888;
		--card-bg: #161616;
		--border: #333;
		--hero-gradient: radial-gradient(circle, rgba(103, 58, 183, 0.15) 0%, rgba(0, 188, 212, 0.05) 50%, transparent 100%);
	}

	@media (prefers-color-scheme: light) {
		:root {
			--bg: #FFFFFF;
			--fg: #1A1A1A;
			--accent-lib: #2E7D32;
			--muted: #666;
			--card-bg: #F8F9FA;
			--border: #E9ECEF;
			--hero-gradient: radial-gradient(circle, rgba(103, 58, 183, 0.08) 0%, rgba(0, 188, 212, 0.03) 50%, transparent 100%);
		}
	}
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		background: var(--bg);
		color: var(--fg);
		scroll-behavior: smooth;
	}
	body {
		min-height: 100vh;
	}
	a {
		color: inherit;
		text-decoration: none;
	}
	code, pre {
		font-family: 'Fira Code', monospace;
	}
	.container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}
	h1, h2, h3 {
		line-height: 1.1;
	}
	p {
		line-height: 1.6;
		color: var(--muted);
	}
</style>
